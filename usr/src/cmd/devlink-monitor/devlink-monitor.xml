<service_bundle type='manifest' name='devlink-monitor'>

<service
	name='system/devlink-monitor'
	type='service'
	version='1'>

	<create_default_instance enabled='true' />

	<single_instance />

	<dependency
		name='filesystem-local'
		grouping='require_all'
		restart_on='none'
		type='service'>
		<service_fmri value='svc:/system/filesystem/local' />
	</dependency>

	<exec_method
		type='method'
		name='start'
		exec='/lib/svc/method/svc-devlink-monitor monitor'
		timeout_seconds='60' />

	<exec_method
		type='method'
		name='stop'
		exec=':kill'
		timeout_seconds='30' />

	<property_group name='config' type='application'>
		<propval name='destdir' type='astring' value='' />
		<propval name='live_dump' type='boolean' value='true' />
		<propval name='interval' type='count' value='10' />
	</property_group>

	<stability value='Unstable' />

	<template>
		<common_name>
			<loctext xml:lang='C'>
			devlink database corruption monitor
			</loctext>
		</common_name>
	</template>
</service>

</service_bundle>
